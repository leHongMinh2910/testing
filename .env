# ===================================
# Library Management System
# Environment Variables Configuration
# ===================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===================================
# Application Configuration
# ===================================
NODE_ENV=production
PORT=3000
WEB_PORT=3000

# ===================================
# Database Configuration (Main MySQL)
# ===================================
# MySQL connection for the main application
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=library_management
MYSQL_USER=library_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_PORT=3306

# Database URL for Prisma (use 'mysql' as hostname in Docker)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://library_user:your_mysql_password@mysql:3306/library_management

# ===================================
# Redis Configuration (Main Redis)
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ===================================
# JWT Configuration
# ===================================
# Generate strong random secrets for production
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===================================
# Default Admin User (for seeding)
# ===================================
# These are used when running the seed script to create the initial admin user
DEFAULT_ADMIN_EMAIL=admin@library.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_FULLNAME=System Administrator

# ===================================
# Socket Server Configuration
# ===================================
SOCKET_PORT=4000

# ===================================
# Gorse Recommender System Configuration
# ===================================

# Gorse MySQL Database
GORSE_MYSQL_ROOT_PASSWORD=your_gorse_mysql_root_password
GORSE_MYSQL_DATABASE=gorse_db
GORSE_MYSQL_USER=gorse_user
GORSE_MYSQL_PASSWORD=your_gorse_mysql_password
GORSE_MYSQL_PORT=3307

# Gorse Redis
GORSE_REDIS_PORT=6380
GORSE_REDIS_PASSWORD=your_gorse_redis_password

# Gorse API Configuration
GORSE_API_PORT=8087
GORSE_DASHBOARD_PORT=8088
GORSE_SERVER_API_KEY=your_gorse_api_key
GORSE_API_HOST=localhost
GORSE_API_URL=http://${GORSE_API_HOST}:${GORSE_DASHBOARD_PORT}

# Email service credentials
EMAIL_USER=
EMAIL_PASSWORD=

# SMTP server configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"  # Set to "true" for port 465, "false" for port 587

EMAIL_FROM="noreply@library.com"

# Socket
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=

# Gemini API key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Qdrant
QDRANT_URL=
QDRANT_API_KEY=

# Ollama models
OLLAMA_HOST=
OLLAMA_EMBED_MODEL=
OLLAMA_SUMMARY_MODEL=
